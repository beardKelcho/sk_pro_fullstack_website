# ============================================
# SK Production - Client Environment Variables
# ============================================
# Bu dosyayı local geliştirme için .env.development.local olarak kopyalayın:
# cp .env.example .env.development.local

# ============================================
# Genel Ayarlar
# ============================================
NODE_ENV=development

# ============================================
# API Configuration
# ============================================
# Backend API URL'i
# Development: http://localhost:5001/api
# Production: https://api.skproduction.com/api
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# Backend Base URL (API URL'den /api kısmını çıkarın)
# Development: http://localhost:5001
# Production: https://api.skproduction.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001

# ============================================
# Site URL
# ============================================
# Frontend URL'i (sitemap, robots.txt için)
# Development: http://localhost:3000
# Production: https://skproduction.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Push Notifications (VAPID Public Key)
# ============================================
# Web Push API için VAPID public key (server'daki VAPID_PUBLIC_KEY ile aynı olmalı)
# Server'dan alın: server/.env dosyasındaki VAPID_PUBLIC_KEY
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ============================================
# Google Analytics (Opsiyonel)
# ============================================
# Google Analytics Tracking ID
# Format: G-XXXXXXXXXX veya UA-XXXXXXXXX-X
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# Google Maps API (Opsiyonel)
# ============================================
# Google Maps API Key (harita gösterimi için)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Sentry Error Tracking (Production)
# ============================================
# Sentry DSN (production error tracking için)
# Dashboard: https://sentry.io/settings/
# Format: https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Sentry Organization ve Project (opsiyonel)
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# Yönetim token'larını client env dosyalarına koymayın.

# App Version (release tracking için)
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SENTRY_RELEASE=1.0.0

# ============================================
# Bundle Analysis (Development)
# ============================================
# Bundle analizi için (development'ta)
# ANALYZE=true npm run build

# ============================================
# Production Notları
# ============================================
# Production'da:
# 1. NODE_ENV=production olarak ayarlayın
# 2. NEXT_PUBLIC_API_URL'yi production backend URL'i ile değiştirin
# 3. NEXT_PUBLIC_SITE_URL'yi production frontend URL'i ile değiştirin
# 4. NEXT_PUBLIC_BACKEND_URL'yi production backend base URL'i ile değiştirin
# 5. NEXT_PUBLIC_VAPID_PUBLIC_KEY'i server'daki VAPID_PUBLIC_KEY ile eşleştirin
# 6. NEXT_PUBLIC_SENTRY_DSN'i production Sentry DSN'i ile değiştirin
# 7. NEXT_PUBLIC_GA_ID'yi production Google Analytics ID'si ile değiştirin (varsa)
# 8. NEXT_PUBLIC_GOOGLE_MAPS_API_KEY'i production Google Maps API key'i ile değiştirin (varsa)
